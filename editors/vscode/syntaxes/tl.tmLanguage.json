{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ThinkingLanguage",
  "scopeName": "source.tl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tl",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tl",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.tl",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#identifiers" },
                { "include": "#numbers" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.tl",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.tl",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tl",
          "match": "\\b(if|else|while|for|in|return|break|continue|match|case|try|catch|throw|await|yield)\\b"
        },
        {
          "name": "keyword.declaration.tl",
          "match": "\\b(let|fn|struct|enum|impl|trait|schema|pipeline|stream|source|sink|use|pub|mod|import|test|where|mut|const|type|model|train)\\b"
        },
        {
          "name": "keyword.operator.logical.tl",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.tl",
          "match": "\\b(as|with|extract|transform|load|connector|parallel|async|emit|self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.tl",
          "match": "\\b(int|int64|float|float64|string|bool|table|list|map|set|any)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.tl",
          "match": "\\b(true|false|none)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.tl",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.tl",
          "match": "->"
        },
        {
          "name": "keyword.operator.fat-arrow.tl",
          "match": "=>"
        },
        {
          "name": "keyword.operator.null-coalesce.tl",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.range.tl",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.scope.tl",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.tl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.tl",
          "match": "\\+=|-=|\\*=|/=|="
        },
        {
          "name": "keyword.operator.arithmetic.tl",
          "match": "\\*\\*|\\+|-|\\*|/|%"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.tl",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.tl" },
            "2": { "name": "entity.name.function.tl" }
          }
        },
        {
          "name": "meta.function.call.tl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.tl" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.tl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
